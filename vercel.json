{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "regions": ["hkg1"],
  "cron": {
    "comment": "Hobby 档不支持 cron(这些配置会被忽略)。生产用 Pro 时,这里定义定时任务触发监控/关键词抓取;Hobby 部署靠设置页手动触发 + HTTP 调用链接力。",
    "schedules": [
      {
        "path": "/api/cron/process",
        "schedule": "*/5 * * * *"
      },
      {
        "path": "/api/cron/monitor-creators",
        "schedule": "0 9 * * *"
      },
      {
        "path": "/api/cron/search-keywords",
        "schedule": "0 10 * * *"
      },
      {
        "path": "/api/cron/refresh-metrics",
        "schedule": "0 0 * * 0"
      }
    ]
  }
}
